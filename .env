# ──────────────────────────────────────────────
# 智能外呼系统 — 本地开发环境变量
# 启动: ./scripts/dev.sh
# ──────────────────────────────────────────────

# PostgreSQL (Docker)
POSTGRES_PASSWORD=postgres

# Ollama
OLLAMA_MODEL=qwen3.5:9b

# ── 可选覆盖 ──
# CALLBOT_LLM_BASE_URL=http://127.0.0.1:11434/v1
# CALLBOT_LLM_MODEL=qwen3.5:9b
# CALLBOT_LLM_DEVICE=cpu
# CALLBOT_MCP_SERVER_URL=http://127.0.0.1:9090/mcp

# ── TTS 流式合成（首包延迟更低） ──
CALLBOT_TTS_USE_WS=true
CALLBOT_TTS_STREAMING_ENABLED=true

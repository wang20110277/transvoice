flowchart LR
    %% ==============================================================================
    %%                 智能外呼全流程技术架构拓扑图 (MRCP ASR/TTS平行布局)
    %%              强制透传: [CallID] & [用户手机号] | 分层流向·协议标注
    %% ==============================================================================

    %% 样式定义
    classDef highlight fill:#fff4e6,stroke:#d9480f,stroke-width:3px,color:#000
    classDef warn fill:#fff0f0,stroke:#c92a2a,stroke-width:2px,stroke-dasharray: 5 5
    classDef storage fill:#e7f5ff,stroke:#1971c2,stroke-width:2px
    classDef core fill:#f8f9fa,stroke:#495057,stroke-width:2px
    classDef event fill:#f3f0ff,stroke:#7950f2,stroke-width:2px

    %% ========================= 第1层：接入与交换层 =========================
    subgraph L1 [接入层与语音交换层]
        A1[SIP User<br/>主叫/被叫终端]:::core
        A2[FreeSWITCH<br/>软交换服务器<br/>媒体流转发/事件调度]:::core
    end

    %% ========================= 第2层：语音处理层 (MRCP ASR 与 MRCP TTS 平行) =========================
    subgraph L2 [语音识别与合成层]
        direction LR
        B1[MRCP ASR<br/>语音识别引擎<br/>语音转文字]:::core
        B2[MRCP TTS<br/>语音合成引擎<br/>文字转语音]:::core
    end

    %% ========================= 第3层：编排接入层 =========================
    subgraph L3 [编排接入层]
        C1[LangGraph<br/>流程编排调度器<br/>全局状态 State]:::highlight
    end

    %% ========================= 第4层：业务服务层 =========================
    subgraph L4 [业务微服务核验层]
        D1[MCP Client<br/>内置编排引擎]:::core
        D2[ESB/RPC 远程调用总线]:::core
        
        subgraph L4_1 [节点1：身份与声纹核验]
            D3[用户中心<br/>User Service<br/>查询用户ID与声纹]:::core
            D5[风控预警1：声纹不符]:::warn
        end
        
        subgraph L4_2 [节点2：贷款与征信核验]
            D4[金融核心系统<br/>征信档案查询]:::core
            D6[风控预警2：征信不合规]:::warn
        end
    end

    %% ========================= 第5层：大模型智能层 =========================
    subgraph L5 [大模型智能层]
        E1[LLM 大模型<br/>语义解析与应答生成]:::core
        E2[RAG 知识库<br/>标准业务话术匹配]:::core
    end

    %% ========================= 第6层：存储层 =========================
    subgraph L6 [记忆与文件存储层]
        F1[(Redis<br/>短期会话记忆)]:::storage
        F2[(PostgreSQL<br/>长期业务数据)]:::storage
        F3[(Mem0<br/>永久全域记忆)]:::storage
        F4[(NAS/OSS<br/>音频原文件与合成语音归档)]:::storage
    end

    %% ========================= 数据流连接（全程透传CallID与手机号） =========================

    %% 1. 接入层 -> 交换层
    A1 -- "SIP 上行<br/><b>携带：CallID, 手机号</b>" --> A2

    %% 2. 交换层 -> MRCP ASR
    A2 -- "UniMRCP 事件通知<br/><b>实时语音流 + CallID + 手机号</b>" --> B1

    %% 3. MRCP ASR -> LangGraph [重点高亮]
    B1 -- "HTTP JSON 推送<br/> *** <b>ASR识别文本 + CallID + 手机号</b> *** " --> C1

    %% 4. 编排层内部节点1 [手机号优先查询]
    C1 -- "节点1：用户身份核验<br/><b>传入手机号</b> 通过MCP调用" --> D1
    D1 -- "MCP协议/ESB/RPC" --> D2
    D2 -- "RPC远程调用<br/><b>优先传入手机号</b>" --> D3
    D3 -. "声纹比对不一致" .-> D5

    %% 5. 编排层内部节点2 [手机号+用户ID查询]
    C1 -- "节点2：贷款征信核验<br/><b>传入手机号+用户ID</b>" --> D1
    D2 -- "RPC远程调用<br/><b>依托双维度查询</b>" --> D4
    D4 -. "征信档案不通过" .-> D6

    %% 6. 编排层节点3直传LLM [重点高亮]
    C1 -- "节点3：State数据提取<br/> *** <b>ASR文本 + CallID + 手机号 + 用户ID</b> *** " --> E1
    
    %% 7. LLM与知识库、存储交互
    E1 -- "检索匹配标准话术" --> E2
    E1 -- "LangChain Memory<br/>分层存储：短期/长期/全域" --> F1
    E1 -- "LangChain Memory<br/>分层存储：短期/长期/全域" --> F2
    E1 -- "LangChain Memory<br/>分层存储：短期/长期/全域" --> F3
    
    %% 8. 音频文件统一归档（原始语音与合成语音均存）
    B1 -. "原始识别语音归档<br/><b>绑定CallID+手机号</b>" .-> F4
    B2 -. "合成应答语音归档<br/><b>绑定CallID+手机号</b>" .-> F4

    %% 9. LangGraph -> MRCP TTS
    C1 -- "HTTP JSON 推送<br/><b>应答话术文本 + CallID + 手机号</b>" --> B2

    %% 10. MRCP TTS -> FreeSWITCH (MRCP回调播放)
    B2 -- "MRCP 回调播放指令<br/><b>合成语音流 + CallID + 手机号</b>" --> A2

    %% 11. 终端播放闭环
    A2 -- "SIP 下行推送合成语音流<br/><b>携带：CallID, 手机号</b>" --> A1

    %% ========================= 高亮连接线 =========================
    %% ASR文本 -> LangGraph -> LLM 的关键路径加粗高亮
    linkStyle 2,5,6 stroke:#d9480f,stroke-width:4px;
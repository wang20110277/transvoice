<document type="freeswitch/xml">
  <section name="dialplan">
    <context name="public">
      <extension name="callbot-entry">
        <condition field="destination_number" expression="^(.*)$">
          <action application="set" data="call_start_time=${strftime(%Y-%m-%d %H:%M:%S)}"/>
          <action application="set" data="biz_type=marketing"/>
          <action application="answer"/>

          <!-- mod_audio_fork: bidirectional audio to agent-flow WebSocket -->
          <!-- rw=read+write (bidirectional), L16/8000 = 16-bit PCM 8kHz -->
          <action application="start_dialplan"/>
          <action application="audio_fork" data="ws://host.docker.internal:8000/ws/call?call_id=${uuid}&amp;biz_type=${biz_type}&amp;user_key=${caller_id_number} rw L16/8000/20"/>
        </condition>
      </extension>
    </context>
  </section>
</document>

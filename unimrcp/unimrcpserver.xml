<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- UniMRCP Server 配置 -->
  <!-- 对接 VibeVoice ASR/TTS 引擎 -->

  <!-- ============ 服务端基础配置 ============ -->
  <settings>
    <!-- 监听地址 -->
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8060"/>

    <!-- 媒体 RTP 端口范围 -->
    <param name="rtp-ip" value="0.0.0.0"/>
    <param name="rtp-port-min" value="50000"/>
    <param name="rtp-port-max" value="60000"/>

    <!-- 信令超时 -->
    <param name="invite-timeout" value="30"/>
    <param name="teardown-timeout" value="10"/>

    <!-- 编解码 -->
    <param name="codecs" value="PCMU PCMA L16 opus"/>

    <!-- 工作线程数 -->
    <param name="worker-threads" value="8"/>

    <!-- 日志配置 -->
    <param name="log-level" value="WARNING"/>
    <param name="log-file" value="/var/log/unimrcp/unimrcpserver.log"/>
  </settings>


  <!-- ============ ASR Resource ============ -->
  <asr-resources>
    <resource name="speech_recog" enabled="true">
      <!-- VibeVoice ASR 服务地址（GPU0） -->
      <param name="backend-url" value="http://10.0.0.20:8080/asr/recognize"/>
      <param name="health-check-url" value="http://10.0.0.20:8080/healthz"/>

      <!-- 超时设置 -->
      <param name="request-timeout" value="10000"/>     <!-- 单次识别超时 10s -->
      <param name="max-stream-duration" value="60000"/> <!-- 流式最大 60s -->

      <!-- 并发控制 -->
      <param name="max-concurrent-sessions" value="50"/>

      <!-- 重试策略 -->
      <param name="retry-count" value="2"/>
      <param name="retry-interval" value="1000"/>

      <!-- VAD 参数 -->
      <param name="vad-enabled" value="true"/>
      <param name="vad-speech-threshold" value="0.5"/>
      <param name="vad-silence-threshold" value="0.3"/>
      <param name="silence-timeout" value="500"/>       <!-- 句子结束静默 500ms -->

      <!-- 输出格式 -->
      <param name="result-format" value="json"/>
      <param name="interim-results" value="true"/>
    </resource>
  </asr-resources>


  <!-- ============ TTS Resource ============ -->
  <tts-resources>
    <!-- TTS Profile: 客服 -->
    <resource name="tts_customer_service" enabled="true">
      <!-- VibeVoice TTS 服务地址（GPU1） -->
      <param name="backend-url" value="http://10.0.0.21:8080/tts/synthesize"/>
      <param name="health-check-url" value="http://10.0.0.21:8080/healthz"/>

      <!-- 超时与并发 -->
      <param name="request-timeout" value="5000"/>
      <param name="max-concurrent-sessions" value="30"/>

      <!-- TTS 参数 -->
      <param name="voice-id" value="cs_female_soft_01"/>
      <param name="speed" value="0"/>
      <param name="volume" value="0"/>
      <param name="pitch" value="0"/>

      <!-- 音频格式 -->
      <param name="audio-format" value="wav"/>
      <param name="sample-rate" value="16000"/>
    </resource>

    <!-- TTS Profile: 催收 -->
    <resource name="tts_collection" enabled="true">
      <param name="backend-url" value="http://10.0.0.21:8080/tts/synthesize"/>
      <param name="health-check-url" value="10.0.0.21:8080/healthz"/>
      <param name="request-timeout" value="5000"/>
      <param name="max-concurrent-sessions" value="30"/>

      <!-- 催收专用音色 -->
      <param name="voice-id" value="col_male_serious_01"/>
      <param name="speed" value="-1"/>
      <param name="volume" value="1"/>
      <param name="pitch" value="-1"/>

      <param name="audio-format" value="wav"/>
      <param name="sample-rate" value="16000"/>
    </resource>

    <!-- TTS Profile: 营销 -->
    <resource name="tts_marketing" enabled="true">
      <param name="backend-url" value="http://10.0.0.21:8080/tts/synthesize"/>
      <param name="health-check-url" value="http://10.0.0.21:8080/healthz"/>
      <param name="request-timeout" value="5000"/>
      <param name="max-concurrent-sessions" value="50"/>

      <!-- 营销专用音色 -->
      <param name="voice-id" value="mkt_female_lively_01"/>
      <param name="speed" value="1"/>
      <param name="volume" value="0"/>
      <param name="pitch" value="1"/>

      <param name="audio-format" value="wav"/>
      <param name="sample-rate" value="16000"/>
    </resource>
  </tts-resources>


  <!-- ============ 监控与健康检查 ============ -->
  <monitoring>
    <param name="enabled" value="true"/>
    <param name="prometheus-port" value="9090"/>
    <param name="metrics-path" value="/metrics"/>

    <!-- 关键指标 -->
    <!-- asr_requests_total, asr_latency_p95, asr_errors_total -->
    <!-- tts_requests_total, tts_latency_p95, tts_errors_total -->
    <!-- active_sessions, queue_length -->
  </monitoring>


  <!-- ============ 资源映射（MRCP Profile -> 后端） ============ -->
  <resource-mapping>
    <!-- FreeSWITCH unimrcp.conf.xml 中的 profile 名称 -->
    <!-- 映射到 UniMRCP 内部的 resource name -->

    <!-- ASR -->
    <map profile="asr_default_v1" resource="speech_recog"/>

    <!-- TTS -->
    <map profile="tts_customer_service_v1" resource="tts_customer_service"/>
    <map profile="tts_collection_v1" resource="tts_collection"/>
    <map profile="tts_marketing_v1" resource="tts_marketing"/>
  </resource-mapping>
</configuration>
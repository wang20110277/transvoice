CALLBOT_PG_DSN=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/callbot
CALLBOT_LLM_DEVICE=cpu
CALLBOT_LLM_BASE_URL=http://127.0.0.1:11434/v1
CALLBOT_LLM_MODEL=qwen3.5:4b
CALLBOT_MCP_SERVER_URL=http://127.0.0.1:9090/mcp
CALLBOT_MCP_TRANSPORT=streamable_http

# ASR 传输方式 (三选一，优先级: WS > gRPC > HTTP)
CALLBOT_ASR_ADAPTER_URL=http://127.0.0.1:8080
CALLBOT_ASR_USE_GRPC=false
CALLBOT_ASR_GRPC_TARGET=127.0.0.1:50051
CALLBOT_ASR_USE_WS=true
CALLBOT_ASR_WS_URL=ws://127.0.0.1:8080/ws/asr/streaming-recognize

# TTS 传输方式 (三选一，优先级: WS > gRPC > HTTP)
CALLBOT_TTS_ADAPTER_URL=http://127.0.0.1:8081
CALLBOT_TTS_USE_GRPC=false
CALLBOT_TTS_GRPC_TARGET=127.0.0.1:50052
CALLBOT_TTS_USE_WS=true
CALLBOT_TTS_WS_URL=ws://127.0.0.1:8081/ws/tts/streaming-synthesize

CALLBOT_TTS_SKIP=false

# VAD (语音端点检测)
CALLBOT_VAD_AGGRESSIVENESS=3
CALLBOT_VAD_SILENCE_FRAMES=40
CALLBOT_VAD_MIN_AUDIO_BYTES=12800

# Barge-in 打断检测
CALLBOT_BARGE_IN_MIN_AUDIO_BYTES=32000

# 降噪 (highpass/noisereduce/rnnoise, 空值=关闭)
CALLBOT_DENOISE_ENABLED=highpass

# Media (uuid_audio_fork 双向音频)
CALLBOT_MEDIA_SAMPLE_RATE=16000
# CALLBOT_MEDIA_WS_HOST=127.0.0.1
# CALLBOT_MEDIA_WS_PORT=8000

# 流式 ASR (引擎级流式，需 ASR 服务使用 streaming 引擎)
CALLBOT_ASR_STREAMING_ENABLED=false

# 流式 TTS (chunk 级流式，需 TTS 服务支持 CosyVoice stream=True)
# 注意: streaming 模式下 send_lock 覆盖整个流，句子串行。batch 模式才支持并发合成。
CALLBOT_TTS_STREAMING_ENABLED=false

# TTS 预缓冲: 累积 N 个 30ms 帧后开始匀速播放 (0=禁用, 10=300ms)
CALLBOT_TTS_PREBUFFER_FRAMES=10

# 句子拆分器调优 (流式优化)
CALLBOT_SPLITTER_MIN_LENGTH=2
CALLBOT_SPLITTER_FLUSH_TIMEOUT=0.2
CALLBOT_SPLITTER_EAGER_FIRST=true
CALLBOT_AUDIO_GAIN=15

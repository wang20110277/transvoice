# ──────────────────────────────────────────────
# 智能外呼系统 环境变量
# 复制为 .env 后按需修改: cp env.example .env
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=postgres

# ── 开发环境 (./scripts/dev.sh) ──────────────
# LLM: Ollama CPU
# ASR/TTS: Dockerfile.cpu
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_PORT=8083
MCP_PORT=9090
# CALLBOT_LLM_DEVICE=cpu          # cpu=Ollama, gpu=vLLM
# CALLBOT_LLM_MODEL=qwen3.5:9b
# CALLBOT_LLM_DEVICE=cpu          # cpu=Ollama, gpu=vLLM

# ── 生产环境 (./scripts/prod.sh) ─────────────
# LLM: vLLM GPU
# ASR/TTS: GPU Dockerfile
# VLLM_MODEL=Qwen/Qwen3.5-9B
# VLLM_SERVED_NAME=qwen3.5:9b
# VLLM_PORT=8083
# VLLM_GPU_IDS=2
# VLLM_MAX_MODEL_LEN=4096
# VLLM_GPU_MEMORY_UTILIZATION=0.9
# ASR_GPU_ID=0
# TTS_GPU_ID=1
# CALLBOT_LLM_BASE_URL=http://host.docker.internal:8083/v1
# CALLBOT_LLM_MODEL=qwen3.5:9b
# CALLBOT_MCP_SERVER_URL=http://host.docker.internal:9090/mcp/

# ── ASR/TTS 传输配置 ─────────────────────────
# 三种传输方式: HTTP / gRPC / WebSocket
# 优先级: WS > gRPC > HTTP (同时启用时高优先级生效)
#
# ASR 传输
# CALLBOT_ASR_ADAPTER_URL=http://127.0.0.1:8080     # HTTP (默认)
# CALLBOT_ASR_USE_GRPC=true                           # gRPC (端口 50051)
# CALLBOT_ASR_GRPC_TARGET=127.0.0.1:50051
# CALLBOT_ASR_USE_WS=false                            # WebSocket
# CALLBOT_ASR_WS_URL=ws://127.0.0.1:8080/ws/asr/streaming-recognize
#
# TTS 传输
# CALLBOT_TTS_ADAPTER_URL=http://127.0.0.1:8081      # HTTP (默认)
# CALLBOT_TTS_USE_GRPC=true                            # gRPC (端口 50052)
# CALLBOT_TTS_GRPC_TARGET=127.0.0.1:50052
# CALLBOT_TTS_USE_WS=false                             # WebSocket
# CALLBOT_TTS_WS_URL=ws://127.0.0.1:8081/ws/tts/streaming-synthesize
#
# TTS 跳过 (本地无 GPU 调试用)
# CALLBOT_TTS_SKIP=false

# ── 流式配置 (Streaming) ─────────────────────
# 引擎级流式: ASR 边听边转, TTS 边收字边合成
# 需 ASR 服务使用 streaming 引擎, TTS 服务支持 CosyVoice stream=True
# CALLBOT_ASR_STREAMING_ENABLED=false
# CALLBOT_TTS_STREAMING_ENABLED=false

# 句子拆分器调优 (流式延迟优化)
# CALLBOT_SPLITTER_MIN_LENGTH=2          # 最小拆分长度 (原 4)
# CALLBOT_SPLITTER_FLUSH_TIMEOUT=0.2     # 超时刷新秒数 (原 0.3)
# CALLBOT_SPLITTER_EAGER_FIRST=true       # 首句加速 (min_length=1)
